{# A commit is marked important by placing U+3164 (Hangul filler) alone on the last
   line of the commit body. Important commits always render above the fold, displacing
   normal commits into <details> if needed. Grep: git log --grep=$'ㅤ' #}
{# Render only the target version (the first tree entry). With --unreleased-version
   the tree still contains every past release; merging them all would fold already
   released commits back into the new section, so restrict rendering to tree[0]. #}
{% set entry = tree | first %}
{% set sections = entry.changes if entry else {} %}
{# Emit sections in change_type_order so headings keep a stable, intended order
   instead of the commit-walk order. Any unlisted keys follow, in tree order. #}
{% set ordered_keys = [] %}
{% for change_key in change_type_order %}
{% if change_key in sections and ordered_keys.append(change_key) %}{% endif %}
{% endfor %}
{% for change_key in sections %}
{% if change_key not in ordered_keys and ordered_keys.append(change_key) %}{% endif %}
{% endfor %}
{# Per-section above-fold limits; breaking changes are never collapsed #}
{% set fold_limits = {
    "‼️ Breaking changes:": none,
    "✨ Features:": 5,
    "🐛 Fixes:": 5,
    "⚙️ Other:": 3
} %}
{% macro render_commit(change) %}
{% if change.scope %}- {{ change.sha }} - **{{ change.scope }}**: {{ change.message }}
{% elif change.message %}- {{ change.sha }} - {{ change.message }}
{% endif %}
{% endmacro %}
{% macro render_fold_commit(change) %}
{%- if change.scope %}• {{ change.sha }} - **{{ change.scope }}**: {{ change.message }}<br>
{%- elif change.message %}• {{ change.sha }} - {{ change.message }}<br>
{%- endif %}
{%- endmacro %}
{% for change_key in ordered_keys %}
{% if change_key %}
#### {{ change_key }}
{% endif %}
{% set fold_limit = fold_limits.get(change_key, 3) %}
{% if fold_limit is none %}
{% for change in sections[change_key] %}{{ render_commit(change) }}{% endfor %}
{% else %}
{% set important = sections[change_key] | selectattr("important") | list %}
{% set normal = sections[change_key] | rejectattr("important") | list %}
{% set normal_slots = [fold_limit - (important | length), 0] | max %}
{% set above_fold = normal[:normal_slots] %}
{% set collapsed = normal[normal_slots:] %}
{% for change in important %}{{ render_commit(change) }}{% endfor %}
{% for change in above_fold %}{{ render_commit(change) }}{% endfor %}
{% if collapsed %}
    ###### <details><summary> Show all {{ section_labels.get(change_key, change_key) }}</summary><br>{% for change in collapsed %}{{ render_fold_commit(change) }}{% endfor %}</details>
{% endif %}
{% endif %}

{% endfor %}
